# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD="your_postgres_password"
POSTGRES_DB=event_ledger
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# LLM / AI Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Agent-specific models (Optimized for Power/Speed/Cost)
DOC_AGENT_MODEL=openai/gpt-4o-mini
CREDIT_AGENT_MODEL=anthropic/claude-3.5-sonnet
FRAUD_AGENT_MODEL=deepseek/deepseek-chat
DECISION_AGENT_MODEL=deepseek/deepseek-r1
COMPLIANCE_AGENT_MODEL=openai/gpt-4o-mini

# Global fallback
LLM_MODEL=openrouter/free

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
